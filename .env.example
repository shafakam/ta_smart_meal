# Copy file ini ke .env lalu isi value aslinya di komputer lokal.
# Jangan commit file .env ke GitHub.

DB_NAME=smart_meal_planner.db
ENCRYPTION_SALT=CHANGE_ME

GEMINI_API_KEY=YOUR_GEMINI_API_KEY
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash

GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
CURRENCY_API_KEY=YOUR_CURRENCY_API_KEY
FOOD_API_BASE_URL=https://www.themealdb.com/api/json/v1/1/

APP_NAME=SmartBite
APP_VERSION=1.0.0
DEBUG_MODE=true
